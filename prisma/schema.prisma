// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources   Source[]
  notebooks Notebook[]
  chats     Chat[]
}

model Source {
  id          String   @id @default(cuid())
  userId      String
  notebookId  String
  name        String
  type        String
  content     String?
  url         String?
  filePath    String?
  fileSize    Int?
  mimeType    String?
  vectorIds   String   @default("")
  status      String   @default("processing")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook    Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  chunks      Chunk[]
}

model Chunk {
  id       String @id @default(cuid())
  sourceId String
  content  String
  metadata String?

  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Notebook {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   Source[]
  chats     Chat[]
}

model Chat {
  id         String   @id @default(cuid())
  userId     String
  notebookId String?
  title      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook   Notebook? @relation(fields: [notebookId], references: [id])
  messages   Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String?
  notebookId String?
  role      String
  content   String
  mode      String?
  sources   String?
  suggestions String?
  createdAt DateTime @default(now())

  chat      Chat?     @relation(fields: [chatId], references: [id])
}